{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/qeeg_session_context.py\"",
            "statusMessage": "Loading qEEG portal pipeline guardrails"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/qeeg_stop_guard.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
